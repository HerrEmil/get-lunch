{
  "name": "get-lunch",
  "type": "module",
  "version": "1.0.0",
  "license": "UNLICENSED",
  "scripts": {
    "start": "node src/local-test-server.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:api": "vitest run src/lambdas/api-server.test.mjs",
    "test:collector": "vitest run src/lambdas/data-collector.test.mjs",
    "test:parsers": "vitest run src/parsers/",
    "dev": "node src/local-test-server.mjs",
    "dev:collection": "node -e \"import('./src/lambdas/data-collector.mjs').then(m => m.handler({}, {awsRequestId: 'dev-test'}))\"",
    "build": "node build.mjs",
    "deploy": "yarn build && serverless deploy",
    "deploy:prod": "yarn build && serverless deploy --stage prod",
    "logs": "serverless logs -f apiServer --tail",
    "logs:collector": "serverless logs -f dataCollector --tail",
    "remove": "serverless remove",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.html": "html-validate",
    "*.{png,jpg,jpeg,webp,avif}": "node tools/check-image-size.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1045.0",
    "@aws-sdk/client-dynamodb": "^3.1045.0",
    "@aws-sdk/lib-dynamodb": "^3.1045.0",
    "jsdom": "^29.1.1",
    "pdfjs-dist": "^5.7.284"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "html-validate": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "osls": "^3.71.0",
    "prettier": "^3.8.3",
    "serverless-api-gateway-caching": "^1.11.0",
    "serverless-domain-manager": "^10.1.0",
    "serverless-dynamodb": "^0.2.58",
    "serverless-offline": "^14.6.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "resolutions": {
    "js-yaml": "^4.1.1",
    "whatwg-url": "^14.0.0",
    "tr46": "^5.0.0",
    "cross-spawn": "^7.0.6",
    "fast-xml-parser": "^5.4.1",
    "tar": "^7.5.3",
    "minimatch": "^5.1.6",
    "qs": "^6.15.0",
    "lodash": "^4.18.1",
    "@smithy/config-resolver": "^4.4.0"
  },
  "overrides": {
    "js-yaml": "^4.1.1",
    "whatwg-url": "^14.0.0",
    "node-fetch>whatwg-url": "^14.0.0",
    "node-fetch>whatwg-url>tr46": "^5.0.0",
    "cross-spawn": "^7.0.6"
  }
}
